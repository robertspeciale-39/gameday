# ── eBay production keyset (developer.ebay.com) ─────────────────
# Leave ALL of these blank to run in DEMO MODE with staged data.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=          # your eBay "RuName", e.g. Rob_Speciale-RobSpeci-gamedy-abcdef
EBAY_ENV=PRODUCTION         # or SANDBOX

# ── Vercel KV (auto-populated when you add the KV integration) ──
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Label options ────────────────────────────────────────────────
LABEL_FORMAT=THERMAL_4X6    # only format in v1
RETURN_ADDRESS_NAME=Gameday Sports Cards
RETURN_ADDRESS_LINE1=7501 W Lake Mead Blvd Ste 111
RETURN_ADDRESS_LINE2=Las Vegas, NV 89128
